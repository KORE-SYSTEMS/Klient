# All settings are optional — Klient works out of the box without any configuration.
# Only set these if you need to customize something.

# NEXTAUTH_SECRET=        # Auto-generated on first start, stored in /app/data/.nextauth-secret
# NEXTAUTH_URL=           # Only needed behind a reverse proxy (e.g. https://klient.yourdomain.com)
# DATABASE_URL=           # Default: file:/app/data/klient.db
