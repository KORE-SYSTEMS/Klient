# Database
DB_PASSWORD=change_me_to_something_strong
DATABASE_URL=postgresql://klient:${DB_PASSWORD}@klient-db:5432/klient

# Auth — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:8399

# SMTP (optional for v1 — needed for invite emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# App
NODE_ENV=production
