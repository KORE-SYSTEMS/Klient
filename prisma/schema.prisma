generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  password       String?
  role           String          @default("CLIENT")
  image          String?
  company        String?
  active         Boolean         @default(true)
  // CRM fields
  phone          String?
  website        String?
  address        String?
  leadStatus     String?         // LEAD | PROSPECT | QUALIFIED | PROPOSAL | WON | LOST
  leadValue      Float?
  leadSource     String?
  tags           String?         // JSON array of tag strings
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  projects       ProjectMember[]
  assignedTasks  Task[]          @relation("assignee")
  timeEntries    TimeEntry[]
  messages       Message[]
  updates        Update[]
  files          File[]          @relation("uploadedBy")
  taskComments   TaskComment[]
  taskActivities TaskActivity[]
  notifications  Notification[]
  notificationSettings NotificationSettings?
  clientNotes      ClientNote[]     @relation("clientNotes")
  clientActivities ClientActivity[] @relation("clientActivities")
  proposals        Proposal[]       @relation("clientProposals")
  fileVersions     FileVersion[]    @relation("fileVersionUploader")
}

model ClientNote {
  id        String   @id @default(cuid())
  title     String?
  content   String
  pinned    Boolean  @default(false)
  client    User     @relation("clientNotes", fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientActivity {
  id          String   @id @default(cuid())
  type        String   // CALL | EMAIL | MEETING | DEMO | PROPOSAL | OTHER
  title       String
  description String?
  date        DateTime @default(now())
  duration    Int?     // minutes
  outcome     String?  // POSITIVE | NEUTRAL | NEGATIVE
  client      User     @relation("clientActivities", fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  authorId    String
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String   // MENTION, TASK_ASSIGNED, TASK_STATUS_CHANGED, TASK_COMMENT, TASK_FILE_UPLOADED, CHAT_MESSAGE, TASK_DUE_SOON
  title     String
  message   String?
  link      String?  // optional in-app href e.g. /projects/xyz/tasks?task=abc
  read      Boolean  @default(false)
  actorId   String?  // user id that triggered (not a relation - just ref)
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model NotificationSettings {
  userId                       String  @id
  user                         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // In-app toggles
  inAppMention                 Boolean @default(true)
  inAppTaskAssigned            Boolean @default(true)
  inAppTaskStatusChanged       Boolean @default(true)
  inAppTaskComment             Boolean @default(true)
  inAppTaskFileUploaded        Boolean @default(true)
  inAppChatMessage             Boolean @default(true)
  inAppTaskDueSoon             Boolean @default(true)
  // Email toggles
  emailMention                 Boolean @default(true)
  emailTaskAssigned            Boolean @default(true)
  emailTaskStatusChanged       Boolean @default(false)
  emailTaskComment             Boolean @default(false)
  emailTaskFileUploaded        Boolean @default(false)
  emailChatMessage             Boolean @default(false)
  emailTaskDueSoon             Boolean @default(true)
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  name      String?
  role      String   @default("CLIENT")
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  status      String          @default("PLANNING")
  color       String?
  dueDate     DateTime?
  archived    Boolean         @default(false)
  hourlyRate  Float?          // default rate for time billing
  budget      Float?          // project budget in currency
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     ProjectMember[]
  tasks       Task[]
  statuses    TaskStatus[]
  epics       Epic[]
  files       File[]
  folders     FileFolder[]
  updates     Update[]
  messages    Message[]
  invoices    Invoice[]
  proposals   Proposal[]
}

model ProjectMember {
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@id([userId, projectId])
}

model TaskStatus {
  id         String  @id
  name       String
  color      String  @default("#6b7280")
  order      Int     @default(0)
  isApproval Boolean @default(false)
  // Semantic bucket used for progress/"done" logic regardless of custom naming.
  // One of: TODO | IN_PROGRESS | DONE
  category   String  @default("IN_PROGRESS")
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
}

model Epic {
  id          String   @id @default(cuid())
  title       String
  description String?
  color       String   @default("#6366f1")
  order       Int      @default(0)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskLink {
  id           String   @id @default(cuid())
  type         String   @default("RELATED")
  sourceTask   Task     @relation("sourceLinks", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  sourceTaskId String
  targetTask   Task     @relation("targetLinks", fields: [targetTaskId], references: [id], onDelete: Cascade)
  targetTaskId String
  createdAt    DateTime @default(now())
}

model Task {
  id            String          @id @default(cuid())
  title         String
  description   String?
  status        String          @default("BACKLOG")
  priority      String          @default("MEDIUM")
  clientVisible Boolean         @default(false)
  dueDate       DateTime?
  order         Int             @default(0)
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  assignee      User?           @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId    String?
  epic          Epic?           @relation(fields: [epicId], references: [id], onDelete: SetNull)
  epicId        String?
  sourceLinks     TaskLink[]      @relation("sourceLinks")
  targetLinks     TaskLink[]      @relation("targetLinks")
  timeEntries     TimeEntry[]
  comments        TaskComment[]
  activities      TaskActivity[]
  files           File[]
  checklistItems  TaskChecklistItem[]
  // Subtasks — self-relation. Subtasks have status/assignee/etc. just like
  // a normal task; they're filtered out of board/list top-level rendering
  // and only shown nested under their parent. Cascade ensures deleting a
  // parent removes all its subtasks.
  parent          Task?           @relation("subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  parentId        String?
  subtasks        Task[]          @relation("subtasks")
  // Approval workflow
  approvalStatus  String?   // null | "PENDING" | "APPROVED" | "REJECTED"
  handoffComment  String?   // comment from team to client when requesting approval
  approvalComment String?   // client's response comment
  approvedAt      DateTime?
  approvedById    String?   // userId who approved/rejected
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TimeEntry {
  id          String    @id @default(cuid())
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  description   String?
  startedAt     DateTime      @default(now())
  stoppedAt     DateTime?
  duration      Int           @default(0) // in seconds, computed on stop
  createdAt     DateTime      @default(now())
  invoiceItems  InvoiceItem[]
}

model FileFolder {
  id          String       @id @default(cuid())
  name        String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  parent      FileFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?
  children    FileFolder[] @relation("FolderTree")
  files       File[]
  createdById String
  createdAt   DateTime     @default(now())
}

model File {
  id            String      @id @default(cuid())
  name          String
  path          String
  size          Int
  mimeType      String
  clientVisible Boolean     @default(false)
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  folder        FileFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folderId      String?
  task          Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskId        String?
  uploadedBy    User        @relation("uploadedBy", fields: [uploadedById], references: [id])
  uploadedById  String
  versions      FileVersion[]
  createdAt     DateTime    @default(now())
}

model FileVersion {
  id           String   @id @default(cuid())
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileId       String
  version      Int
  path         String
  size         Int
  note         String?
  uploadedBy   User     @relation("fileVersionUploader", fields: [uploadedById], references: [id])
  uploadedById String
  createdAt    DateTime @default(now())

  @@unique([fileId, version])
}

model Update {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("INFO")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  content   String
  filePath  String?
  fileName  String?
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  createdAt DateTime @default(now())
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  mentions  String   @default("[]") // JSON array of user IDs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Lightweight checklist items ("sub-tasks") attached to a Task.
/// Deliberately not a full Task (no status/assignee/etc.) — just a title + done
/// flag + sort order. Surfaced as `_count.checklistItems` / `checklistDone`
/// on kanban cards so teams see progress at a glance.
model TaskChecklistItem {
  id        String   @id @default(cuid())
  title     String
  done      Boolean  @default(false)
  order     Int      @default(0)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, order])
}

model TaskActivity {
  id        String   @id @default(cuid())
  type      String   // STATUS_CHANGE, ASSIGNMENT, COMMENT, FILE_UPLOAD, PRIORITY_CHANGE, CREATED, TIME_ENTRY
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  oldValue  String?
  newValue  String?
  metadata  String?  // JSON for extra info
  createdAt DateTime @default(now())
}

model Invoice {
  id          String        @id @default(cuid())
  number      String
  title       String
  status      String        @default("DRAFT") // DRAFT | SENT | PAID | CANCELLED
  taxRate     Int           @default(19)       // MwSt. %
  dueDate     DateTime?
  issuedAt    DateTime      @default(now())
  paidAt      DateTime?
  notes       String?
  shareToken  String?       @unique
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  items       InvoiceItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Proposal {
  id          String         @id @default(cuid())
  number      String
  title       String
  status      String         @default("DRAFT") // DRAFT | SENT | ACCEPTED | DECLINED | EXPIRED
  taxRate     Int            @default(19)
  validUntil  DateTime?
  issuedAt    DateTime       @default(now())
  notes       String?
  shareToken  String?        @unique
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  client      User?          @relation("clientProposals", fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  items       ProposalItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProposalItem {
  id          String   @id @default(cuid())
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  unit        String   @default("Std.")
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposalId  String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  unit        String   @default("Std.") // Std., Stk., Pauschal, etc.
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  timeEntry   TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  timeEntryId String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Workspace {
  id                      String  @id @default(cuid())
  name                    String  @default("Klient")
  logo                    String?
  primaryColor            String  @default("#E8520A")
  // SMTP
  smtpHost                String?
  smtpPort                Int     @default(587)
  smtpUser                String?
  smtpPass                String?
  smtpFrom                String?
  // Mail templates
  inviteEmailSubject      String?
  inviteEmailTemplate     String?
  invoiceEmailSubject     String?
  invoiceEmailTemplate    String?
  updateEmailSubject      String?
  updateEmailTemplate     String?
  // Billing / company
  companyName             String?
  companyAddress          String?
  companyTaxId            String?   // USt-IdNr.
  companyIban             String?
  currency                String  @default("EUR")
  defaultHourlyRate       Float?
  defaultTaxRate          Int     @default(19)  // MwSt. %
  invoicePrefix           String  @default("RE")
  proposalPrefix          String  @default("AN")
  paymentTermsDays        Int     @default(14)
}
